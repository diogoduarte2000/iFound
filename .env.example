# =============================================================================
# iFound — Docker Environment Variables
# =============================================================================
# Copy to .env and fill in the values.

# Traefik routing
EXTERNAL_DOMAIN=zerodown.top
INTERNAL_DOMAIN=home.local

# JWT authentication secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# Resend API key (for 2FA email delivery)
RESEND_API_KEY=

# SMTP (optional fallback, only if not using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
